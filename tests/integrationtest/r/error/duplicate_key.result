CREATE TABLE t (a INT PRIMARY KEY, b INT)
INSERT INTO t VALUES (1, 10)
AFFECTED 1
SELECT * FROM t
a	b
1	10
INSERT INTO t VALUES (1, 20)
ERROR 1062: DuplicateKey
SELECT * FROM t
a	b
1	10
INSERT INTO t VALUES (2, 20)
AFFECTED 1
SELECT * FROM t ORDER BY a
a	b
1	10
2	20
INSERT INTO t VALUES (2, 30)
ERROR 1062: DuplicateKey
DROP TABLE t
CREATE TABLE t2 (a INT, b INT, c INT, PRIMARY KEY (a, b))
INSERT INTO t2 VALUES (1, 1, 100)
AFFECTED 1
INSERT INTO t2 VALUES (1, 2, 200)
AFFECTED 1
INSERT INTO t2 VALUES (2, 1, 300)
AFFECTED 1
INSERT INTO t2 VALUES (1, 1, 999)
ERROR 1062: DuplicateKey
SELECT * FROM t2 ORDER BY a, b
a	b	c
1	1	100
1	2	200
2	1	300
DROP TABLE t2
CREATE TABLE t3 (id INT PRIMARY KEY, name VARCHAR(100))
INSERT INTO t3 VALUES (1, 'Alice')
AFFECTED 1
INSERT INTO t3 VALUES (2, 'Bob')
AFFECTED 1
INSERT INTO t3 VALUES (3, 'Charlie')
AFFECTED 1
SELECT * FROM t3 ORDER BY id
id	name
1	Alice
2	Bob
3	Charlie
UPDATE t3 SET id = 1 WHERE id = 2
ERROR 1062: DuplicateKey
SELECT * FROM t3 ORDER BY id
id	name
1	Alice
2	Bob
3	Charlie
UPDATE t3 SET id = 10 WHERE id = 3
AFFECTED 1
SELECT * FROM t3 ORDER BY id
id	name
1	Alice
2	Bob
10	Charlie
DROP TABLE t3
