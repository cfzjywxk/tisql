CREATE TABLE txn_test (id INT PRIMARY KEY, val VARCHAR(100))
INSERT INTO txn_test VALUES (1, 'original')
AFFECTED 1
BEGIN
UPDATE txn_test SET val = 'modified_by_s1' WHERE id = 1
AFFECTED 1
