CREATE TABLE rollback_test (id INT PRIMARY KEY, val INT)
INSERT INTO rollback_test VALUES (1, 100)
AFFECTED 1
INSERT INTO rollback_test VALUES (2, 200)
AFFECTED 1
BEGIN
UPDATE rollback_test SET val = 999 WHERE id = 1
AFFECTED 1
UPDATE rollback_test SET val = 888 WHERE id = 2
AFFECTED 1
SELECT * FROM rollback_test ORDER BY id
id	val
1	999
2	888
ROLLBACK
SELECT * FROM rollback_test ORDER BY id
id	val
1	100
2	200
SELECT * FROM rollback_test ORDER BY id
id	val
1	100
2	200
UPDATE rollback_test SET val = 300 WHERE id = 1
AFFECTED 1
SELECT * FROM rollback_test WHERE id = 1
id	val
1	300
DROP TABLE rollback_test
