# Duplicate key error tests

# Setup: create table with primary key
CREATE TABLE t (a INT PRIMARY KEY, b INT);

# Insert first row - should succeed
INSERT INTO t VALUES (1, 10);

# Verify row exists
SELECT * FROM t;

# Insert duplicate primary key - should fail with 1062
--error 1062
--error_kind DuplicateKey
--error_contains PRIMARY
INSERT INTO t VALUES (1, 20);

# Verify original row unchanged
SELECT * FROM t;

# Insert another row with different key - should succeed
INSERT INTO t VALUES (2, 20);

# Verify both rows exist
SELECT * FROM t ORDER BY a;

# Insert duplicate again - should fail
--error 1062
--error_kind DuplicateKey
INSERT INTO t VALUES (2, 30);

# Cleanup
DROP TABLE t;

# Test composite primary key
CREATE TABLE t2 (a INT, b INT, c INT, PRIMARY KEY (a, b));

INSERT INTO t2 VALUES (1, 1, 100);
INSERT INTO t2 VALUES (1, 2, 200);
INSERT INTO t2 VALUES (2, 1, 300);

# Duplicate composite key
--error 1062
--error_kind DuplicateKey
INSERT INTO t2 VALUES (1, 1, 999);

SELECT * FROM t2 ORDER BY a, b;

DROP TABLE t2;

# Test UPDATE changing primary key to duplicate value
CREATE TABLE t3 (id INT PRIMARY KEY, name VARCHAR(100));

INSERT INTO t3 VALUES (1, 'Alice');
INSERT INTO t3 VALUES (2, 'Bob');
INSERT INTO t3 VALUES (3, 'Charlie');

SELECT * FROM t3 ORDER BY id;

# Update to change PK to existing value - should fail
--error 1062
--error_kind DuplicateKey
UPDATE t3 SET id = 1 WHERE id = 2;

# Verify data unchanged
SELECT * FROM t3 ORDER BY id;

# Update to change PK to non-existing value - should succeed
UPDATE t3 SET id = 10 WHERE id = 3;

SELECT * FROM t3 ORDER BY id;

DROP TABLE t3;
