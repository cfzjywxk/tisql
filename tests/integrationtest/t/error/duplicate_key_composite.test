# Duplicate key errors on composite primary keys.

CREATE TABLE t2 (a INT, b INT, c INT, PRIMARY KEY (a, b));

INSERT INTO t2 VALUES (1, 1, 100);
INSERT INTO t2 VALUES (1, 2, 200);
INSERT INTO t2 VALUES (2, 1, 300);

--error 1062
--error_kind DuplicateKey
INSERT INTO t2 VALUES (1, 1, 999);

SELECT * FROM t2 ORDER BY a, b;

DROP TABLE t2;
