# TXN-026: Explicit transaction survives statement errors.
#
# Keep this deterministic: use duplicate-key errors inside one explicit
# transaction rather than lock waits that can block unpredictably.

CREATE TABLE error_survive_test (id INT PRIMARY KEY, val INT);

--session s2
BEGIN;
INSERT INTO error_survive_test VALUES (1, 100);

--error 1062
--error_kind DuplicateKey
INSERT INTO error_survive_test VALUES (1, 999);

# The explicit transaction should still be alive after the error.
SELECT 1;
INSERT INTO error_survive_test VALUES (2, 200);
COMMIT;

--session s1
SELECT * FROM error_survive_test ORDER BY id;

DROP TABLE error_survive_test;
