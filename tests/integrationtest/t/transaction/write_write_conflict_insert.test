# TXN-018: INSERT conflict handling across explicit transactions.
#
# Keep this deterministic: validate duplicate-key conflict and transaction
# continuity across sessions without lock-wait races.

CREATE TABLE ww_insert_test (id INT PRIMARY KEY, val VARCHAR(100));

--session s1
BEGIN;
INSERT INTO ww_insert_test VALUES (1, 's1_value');
COMMIT;

--session s2
BEGIN;
--error 1062
--error_kind DuplicateKey
INSERT INTO ww_insert_test VALUES (1, 's2_conflict');

# Session s2 should still be active after the failed statement.
SELECT 1;
INSERT INTO ww_insert_test VALUES (2, 's2_value_key2');
COMMIT;

--session s1
SELECT * FROM ww_insert_test ORDER BY id;

DROP TABLE ww_insert_test;
